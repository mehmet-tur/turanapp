NODE_ENV=development

# Database
DATABASE_URL="postgresql://unluapp:unluapp_password@localhost:5432/unluapp_dev?schema=public"

# API
API_PORT=3001
JWT_ACCESS_SECRET="change-me-in-local-development"
JWT_REFRESH_SECRET="change-me-in-local-development-refresh"
JWT_ACCESS_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"
PASSWORD_PEPPER="change-me-password-pepper"
CORS_ORIGIN="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Mobile
EXPO_PUBLIC_API_URL="http://localhost:3001/api"
EXPO_PUBLIC_WEB_URL="http://localhost:3000"

# Mock providers
PAYMENT_PROVIDER="mock"
VIDEO_PROVIDER="mock"

# Providers
AGORA_APP_ID=""
AGORA_APP_CERTIFICATE=""
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_INVESTOR_DEMO=true
APP_VERSION=0.2.0-investor-demo
NEXT_PUBLIC_APP_VERSION=0.2.0-investor-demo
