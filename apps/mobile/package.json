{
  "name": "mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app src lib --ext .ts,.tsx",
    "test": "tsx --test src/lib/*.spec.ts",
    "format": "prettier --write \"app/**/*.tsx\" \"src/**/*.ts\" \"src/**/*.tsx\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "expo": "~53.0.12",
    "expo-router": "~5.1.0",
    "expo-secure-store": "~14.2.3",
    "react": "19.0.0",
    "react-native": "0.79.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.8",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
